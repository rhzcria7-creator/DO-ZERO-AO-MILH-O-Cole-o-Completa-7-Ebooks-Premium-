rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /purchases/{purchaseId} {
      // SECURE: Only the backend webhook (Admin SDK) can write purchases.
      // Users can NEVER create or modify their own purchase status.
      allow create, update, delete: if false;
      
      // Users can only read their own securely confirmed purchases.
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
    }
  }
}
