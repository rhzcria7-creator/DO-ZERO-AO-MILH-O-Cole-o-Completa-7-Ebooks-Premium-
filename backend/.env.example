# ===========================================
# SERVIDOR
# ===========================================
NODE_ENV=development
PORT=3000
TRUST_PROXY=true

# ===========================================
# DOMÍNIOS (CORS) - separados por vírgula
# ===========================================
ALLOWED_ORIGINS=http://localhost:5173

# ===========================================
# SESSÃO (CSRF + cookies)
# ===========================================
# Gere com: openssl rand -hex 64
COOKIE_SECRET=your-64-char-secret-here

# ===========================================
# BANCO DE DADOS (PostgreSQL)
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/dozeroaomilhao

# ===========================================
# STRIPE (Opcional - pode estar desabilitado)
# ===========================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...

# ===========================================
# E-MAIL (SendGrid ou SMTP)
# ===========================================
# Provider: sendgrid ou smtp
EMAIL_PROVIDER=sendgrid

# SendGrid (recomendado)
# SENDGRID_API_KEY=SG....

# SMTP (alternativa)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASS=sua-senha-de-app

# Configurações do remetente
EMAIL_FROM=noreply@dozeroaomilhao.com
EMAIL_FROM_NAME=Do Zero ao Milhão

# ===========================================
# DOWNLOAD SEGURO
# ===========================================
# Gere com: openssl rand -hex 64
DOWNLOAD_SECRET=your-64-char-secret-here

# URL base da API (sem trailing slash)
DOWNLOAD_URL=http://localhost:3000

# Caminho para o arquivo do eBook (privado, não público)
# DOWNLOAD_FILE_PATH=/var/www/ebooks/ebook.pdf

# ===========================================
# TOKEN HMAC (opcional)
# ===========================================
# Usa DOWNLOAD_SECRET se não definido
# TOKEN_SECRET=your-64-char-secret-here

# ===========================================
# NEWSLETTER (Opcional - Mailchimp)
# ===========================================
# MAILCHIMP_API_KEY=...
# MAILCHIMP_LIST_ID=...

# ===========================================
# ADMIN (Opcional)
# ===========================================
# Gere o hash com: node -e "console.log(require('./backend/src/services/auth').hashPassword('sua-senha'))"
# ADMIN_EMAIL=admin@dozeroaomilhao.com
# ADMIN_PASSWORD_HASH=salt:hash

# ===========================================
# LOG
# ===========================================
LOG_LEVEL=info